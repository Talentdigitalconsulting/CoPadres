# ============================================================
# CoPadres — Variables de entorno
# Copia este archivo como .env.local y rellena cada valor.
# El TUTORIAL.md explica dónde conseguir cada clave paso a paso.
# ============================================================

# --- Supabase (Proyecto > Settings > API) ---
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # ¡Solo en el servidor! Nunca la expongas.

# --- URL pública de la app (en local: http://localhost:3000) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Anthropic / Claude (para el filtro de tono y el asistente) ---
ANTHROPIC_API_KEY=sk-ant-...
# Modelo barato para tareas sencillas (filtro de tono):
ANTHROPIC_MODEL_RAPIDO=claude-3-5-haiku-latest
# Modelo para el asistente y los resúmenes:
ANTHROPIC_MODEL_ASISTENTE=claude-sonnet-4-20250514

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_o_sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Opción A (recomendada para empezar): Payment Links creados en el panel de Stripe.
# Pega aquí tus enlaces de pago y la página de precios los usará directamente.
NEXT_PUBLIC_STRIPE_LINK_INDIVIDUAL=
NEXT_PUBLIC_STRIPE_LINK_FAMILIA=
# Opción B (checkout integrado): IDs de precio (Products > Pricing) si prefieres
# el checkout dentro de la app en lugar de Payment Links.
STRIPE_PRICE_INDIVIDUAL=price_...
STRIPE_PRICE_FAMILIA=price_...
